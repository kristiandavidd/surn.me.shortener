// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  sessions  Session[]
  links     Link[]
  linkTrees LinkTree[]

  @@map("user")
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime

  @@map("session")
  @@index([userId])
}

model VerificationToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime

  @@map("verification_token")
}

model Link {
  id        String   @id @default(cuid())
  shortCode String   @unique
  longUrl   String
  title     String?
  createdAt DateTime @default(now())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("link")
}

model LinkTree {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  description String?
  image       String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  items       LinkTreeItem[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("link_tree")
}

model LinkTreeItem {
  id          String   @id @default(cuid())
  title       String
  url         String
  icon        String?
  linkTreeId  String
  linkTree    LinkTree @relation(fields: [linkTreeId], references: [id], onDelete: Cascade)
  order       Int      @default(0)

  @@map("link_tree_item")
}
